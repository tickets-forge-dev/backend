rules_version = '2';

// Forge Storage Security Rules
//
// Architecture: File uploads/downloads go through the NestJS backend using
// the Admin SDK. These rules block direct client SDK access to Storage.
//
// Storage paths:
//   /attachments/{workspaceId}/{aecId}/{fileId}-{filename}

service firebase.storage {
  match /b/{bucket}/o {

    // Attachments — no direct client access (backend proxies all uploads/downloads)
    match /attachments/{workspaceId}/{aecId}/{allPaths=**} {
      allow read, write: if false; // Admin SDK only
    }

    // Catch-all: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
